{
  "enabledManagers": ["dockerfile", "github-actions"],
  "dockerfile": {
    "fileMatch": [".*Containerfile$"]
  },
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehavior": "timestamp-optional",
  "packageRules": [
    {
      "matchDepTypes": ["uses-with"],
      "enabled": false
    }
  ]
}
